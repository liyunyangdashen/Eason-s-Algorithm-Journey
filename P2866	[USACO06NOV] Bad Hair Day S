#include<iostream>
#include<stack>
using namespace std; const int N = 8e4 + 5;
int n,a[N]; long long ans; stack<int> s;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n;
    for (int i = 1;i <= n;i++){
        cin >> a[i];
        while (!s.empty() && a[s.top()] <= a[i])
            s.pop();
        if (!s.empty())
            ans += s.size();
        s.push(i);
    }
    cout << ans;
    return 0;
}
