#include<iostream>
#include<stack>
using namespace std; const int N = 3e6 + 5;
int n,a[N],k[N]; stack<int> s;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n;
    for (int i = 1;i <= n;i++)
        cin >> a[i];
    for (int i = n;i >= 1;i--){
        while (!s.empty() && a[s.top()] <= a[i])
            s.pop();
        if (!s.empty())
            k[i] = s.top();
        s.push(i);
    }
    for (int i = 1;i <= n;i++)
        cout << k[i] << ' ';
    return 0;
}
