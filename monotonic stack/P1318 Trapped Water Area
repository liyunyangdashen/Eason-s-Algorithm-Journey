#include<iostream>
#include<stack>
using namespace std; const int N = 1e4 + 5;
int n,a[N],ans; stack<int> s;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n;
    for (int i = 1;i <= n;i++){
        cin >> a[i];
        while (!s.empty() && a[s.top()] < a[i]){
            int m = s.top();
            s.pop();
            if (s.empty()) break;
            int l = s.top(),h = min(a[l],a[i]) - a[m],w = i - l - 1;
            ans += h * w;
        }
        s.push(i);
    }
    cout << ans;
    return 0;
}
