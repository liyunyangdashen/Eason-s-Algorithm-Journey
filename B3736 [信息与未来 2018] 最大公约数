#include<iostream>
using namespace std;
int x,y,z;
int gcd(int a,int b){
    int r;
    while (b){
        r = a % b;
        a = b;
        b = r;
    }
    return a;
}
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> x >> y >> z;
    cout << gcd(x,gcd(y,z));
    return 0;
}
