#include<iostream>
#include<cmath>
using namespace std; const int N = 1e5 + 5;
int n,m,st[N][20],l,r;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n >> m;
    for (int i = 1;i <= n;i++)
        cin >> st[i][0];
    for (int j = 1;j <= log2(n);j++)
        for (int i = 1;i + (1 << j) - 1 <= n;i++)
            st[i][j] = min(st[i][j - 1],st[i + (1 << (j - 1))][j - 1]);
    while (m--){
        cin >> l >> r;
        int k = log2(r - l + 1);
        cout << min(st[l][k],st[r - (1 << k) + 1][k]) << ' ';
    }
    return 0;
}
