#include<iostream>
using namespace std; const int N = 1e7 + 5;
int n,a[N],f[N],ans = -2e9;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n;
    for (int i = 1;i <= n;i++){
        cin >> a[i];
        f[i] = max(a[i],f[i - 1] + a[i]);
        ans = max(ans,f[i]);
    }
    cout << ans;
    return 0;
}
