#include<iostream>
using namespace std; const int N = 1e5 + 5;
int n,k,a[N],maxx,mod; long long cnt;
int main(){
    ios::sync_with_stdio(0);
    cin.tie(0);
    cout.tie(0);
    cin >> n >> k;
    for (int i = 1;i <= n;i++){
        cin >> a[i];
        maxx = max(maxx,a[i]);
    }
    mod = a[1] % k;
    for (int i = 1;i <= n;i++){
        if (a[i] % k == mod)
            cnt += (maxx - a[i]) / k;
        else{
            cout << "NO";
            exit(0);
        }
    }
    cout << "YES " << cnt;
    return 0;
}
