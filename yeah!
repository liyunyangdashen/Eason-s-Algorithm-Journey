#include<iostream>
#include<algorithm>
using namespace std; const int N = 2e4 + 5,M = 1e5 + 5;
struct criminal{int p1,p2,g;}p[M];
int n,m,fa[2 * N];
bool cmp (criminal A,criminal B){return A.g < B.g;}
int findRt(int x){if (fa[x] == x) return x; return fa[x] = findRt(fa[x]);}
void unionn(int x,int y){int fx = findRt(x),fy = findRt(y); if (fx > fy) swap(fx,fy); if (fx != fy) fa[fx] = fy;}
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n >> m;
    for (int i = 1;i <= 2 * n;i++)
        fa[i] = i;
    for (int i = 1;i <= m;i++)
        cin >> p[i].p1 >> p[i].p2 >> p[i].g;
    sort(p + 1,p + m + 1,cmp);
    for (int i = m;i > 0;i--){
        if (findRt(p[i].p1) == findRt(p[i].p2)){
            cout << p[i].g;
            exit(0);
        }
        unionn(p[i].p1,p[i].p2 + n),
        unionn(p[i].p1 + n,p[i].p2);
    }
    cout << 0;
    return 0;
}
