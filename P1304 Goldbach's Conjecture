#include<iostream>
using namespace std; const int N = 10005;
int n,p[N],cnt; bool vis[N];
void EulerSieve(int n){
    vis[0] = vis[1] = 1;
    for (int i = 2;i <= n;i++){
        if (!vis[i]) p[++cnt] = i;
        for (int j = 1;j <= cnt && i * p[j] <= n;j++){
            vis[i * p[j]] = 1;
            if (!(i % p[j])) break;
        }
    }
}
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n;
    EulerSieve(n);
    for (int i = 4;i <= n;i += 2)
        for (int j = 1;j <= cnt && p[j] <= i;j++)
            if (!vis[i - p[j]]){
                cout << i << '=' << p[j] << '+' << i - p[j] << '\n';
                break;
            }
    return 0;
}
