#include<iostream>
#include<cstring>
using namespace std; const int N = 1005,W = 10005;
int n,w,a[N],f[W];
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n >> w;
    memset(f,0x3f,sizeof(f));
    for (int i = 1;i <= n;i++){
        cin >> a[i];
        f[a[i]] = 1;
    }
    for (int j = 1;j <= n;j++)
        for (int i = a[j];i <= w;i++)
            f[i] = min(f[i],f[i - a[j]] + 1);
    cout << f[w];
    return 0;
}
