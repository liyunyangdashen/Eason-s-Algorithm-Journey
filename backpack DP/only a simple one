#include<iostream>
using namespace std; const int N = 30,T = 3e4 + 5;
int n,t,c[N],v[N],f[T];
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> t >> n;
    for (int i = 1;i <= n;i++){
        cin >> c[i] >> v[i];
        for (int j = t;j >= c[i];j--)
            f[j] = max(f[j],f[j - c[i]] + c[i] * v[i]);
    }
    cout << f[t];
    return 0;
}
 
