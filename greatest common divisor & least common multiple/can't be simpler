#include<iostream>
using namespace std; 
int a,b,c; double sine;
int gcd(int a,int b){
    int r = a % b;
    while (r)
        a = b,
        b = r,
        r = a % b;
    return b;
}
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> a >> b >> c;
    if (a > b) swap(a,b);
    if (b > c) swap(b,c);
    if (a > b) swap(a,b);
    sine = a * 1.0 / c;
    if (sine != int(sine))
        cout << a / gcd(a,c) << '/' << c / gcd(a,c);
    else
        cout << sine;
    return 0;
}
