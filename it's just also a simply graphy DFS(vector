#include<iostream>
#include<vector>
#include<cstring>
using namespace std; const int N = 1e5 + 5;
int n,m,u,v,vis[N],maxx; vector<int> a[N];
void dfs(int st){
    maxx = max(maxx,st);
    for (int i = 0;i < a[st].size();i++)
        if (!vis[a[st][i]])
            vis[a[st][i]] = 1,
            dfs(a[st][i]);
}
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n >> m;
    while (m--){
        cin >> u >> v;
        a[u].push_back(v);
    }
    for (int i = 1;i <= n;i++){
        memset(vis,0,sizeof(vis));
        vis[i] = 1;
        maxx = i;
        dfs(i);
        cout << maxx << ' ';
    }
    return 0;
}
