#include<iostream>
#include<stack>
using namespace std; const int N = 3e5 + 5;
int n,a[N],minn,l[N],r[N]; long long maxx; stack <int> s;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n;
    for (int i = 1;i <= n;i++){
        cin >> a[i];
        while (!s.empty() && a[s.top()] >= a[i])
            s.pop();
        if (!s.empty())
            l[i] = s.top();
        else
            l[i] = 0;
        s.push(i);
    }
    while (!s.empty())
        s.pop();
    for (int i = n;i >= 1;i--){
        while (!s.empty() && a[s.top()] >= a[i])
            s.pop();
        if (!s.empty())
            r[i] = s.top();
        else
            r[i] = n + 1;
        s.push(i);
    }
    for (int i = 1;i <= n;i++)
        maxx = max(maxx,1LL * a[i] * ((r[i] - 1) - (l[i] + 1) + 1));
    cout << maxx;
    return 0;
}
//兄弟，这道题的本质其实就是著名的 “直方图最大矩形面积” 问题（Histogram Largest Rectangle）。
题目要求的是 $(R-L+1) \cdot \min(A_L, \dots, A_R)$ 的最大值。这意味着对于每一个元素 $A_i$，
如果把它当作区间里的最小值，我们只需要找到：
左边第一个比 $A_i$ 小的元素位置 left。右边第一个比 $A_i$ 小的元素位置 right。
那么以 $A_i$ 为最小值的最大区间长度就是 (right - 1) - (left + 1) + 1，
也就是 right - left - 1。
为什么用单调栈？我们需要在线性时间 $O(n)$ 内求出每个元素的左边界和右边界。单调栈正是做这件事的神器。
