#include<iostream>
#include<deque>
using namespace std; const int N = 1e5 + 5;
int n,m,a[N]; deque<int> dq;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n >> m;
    for (int i = 1;i <= n;i++){
        cin >> a[i];
        while (!dq.empty() && dq.front() + m - 1 < i)
            dq.pop_front();
        while (!dq.empty() && a[dq.back()] >= a[i])
            dq.pop_back();
        dq.push_back(i);
        if (i >= m)
            cout << a[dq.front()] << '\n';
    }
    return 0;
}
