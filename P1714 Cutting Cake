#include<iostream>
#include<deque>
using namespace std; const int N = 5e5 + 5;
int n,m,p[N]; int maxx = -1e9; deque<int> dq;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n >> m;
    for (int i = 1;i <= n;i++){
        cin >> p[i];
        p[i] += p[i - 1];
        while (!dq.empty() && dq.front() + m - 1 < i)
            dq.pop_front();
        while (!dq.empty() && p[dq.back() - 1] > p[i - 1])
            dq.pop_back();
        dq.push_back(i);
        if (!dq.empty())
            maxx = max(maxx,p[i] - p[dq.front() - 1]);
    }
    cout << maxx;
    return 0;
}
