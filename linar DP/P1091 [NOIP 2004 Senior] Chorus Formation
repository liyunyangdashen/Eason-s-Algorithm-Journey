 #include<iostream>
using namespace std; const int N = 105;
int n,a[N],fl[N],fr[N],maxx;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n;
    for (int i = 1;i <= n;i++){
        cin >> a[i];
        fl[i] = 1;
        for (int j = 1;j < i;j++)
            if (a[i] > a[j])
                fl[i] = max(fl[i],fl[j] + 1);
    }
    for (int i = n;i >= 1;i--){
        fr[i] = 1;
        for (int j = n;j > i;j--)
            if (a[i] > a[j])
                fr[i] = max(fr[i],fr[j] + 1);
        maxx = max(maxx,fl[i] + fr[i] - 1);
    }
    cout << n - maxx;
    return 0;
}
