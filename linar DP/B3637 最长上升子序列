#include<iostream>
using namespace std; const int N = 5005;
int n,a[N],f[N],maxx;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n;
    for (int i = 1;i <= n;i++){
        cin >> a[i];
        f[i] = 1;
        for (int j = 1;j < i;j++)
            if (a[i] > a[j])
                f[i] = max(f[i],f[j] + 1);
        maxx = max(maxx,f[i]);
    }
    cout << maxx;
    return 0;
}
