#include<iostream>
#include<cstring>
#include<queue>
using namespace std; const int N = 205;
int n,s,e,g[N],vis[N],dis[N],dx[] = {1,-1};
void bfs(int st){
    vis[st] = 1;
    dis[st] = 0;
    queue<int> q;
    q.push(st);
    while (!q.empty()){
        int f = q.front();
        q.pop();
        for (int i = 0;i < 2;i++){
            int nf = f + dx[i] * g[f];
            if (!vis[nf] && (nf > 0 && nf <= n))
                vis[nf] = 1,
                dis[nf] = dis[f] + 1,
                q.push(nf);
        }
    }
}
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n >> s >> e;
    for (int i = 1;i <= n;i++)
        cin >> g[i];
    memset(dis,-1,sizeof(dis));
    bfs(s);
    cout << dis[e];
    return 0;
}
  
