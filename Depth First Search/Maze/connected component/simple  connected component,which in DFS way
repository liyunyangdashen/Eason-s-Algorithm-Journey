#include<iostream>
using namespace std; const int N = 35;
int rc,g[N][N],vis[N][N],dx[] = {-1,1,0,0},dy[] = {0,0,-1,1}; 
void dfs(int stx,int sty){
    for (int i = 0;i < 4;i++){
        int nx = stx + dx[i],ny = sty + dy[i];
        if ((nx > 0 && nx <= rc && ny > 0 && ny <= rc) && !(vis[nx][ny] || g[nx][ny]))
            vis[nx][ny] = 1,
            dfs(nx,ny);
    }
}
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> rc;
    for (int i = 1;i <= rc;i++)
        for (int j = 1;j <= rc;j++)
            cin >> g[i][j];
    for (int i = 1;i <= rc;i++){
        if (!vis[1][i] && !g[1][i]) vis[1][i] = 1,dfs(1,i);
        if (!vis[i][1] && !g[i][1]) vis[i][1] = 1,dfs(i,1);
        if (!vis[rc][i] && !g[rc][i]) vis[rc][i] = 1,dfs(rc,i);
        if (!vis[i][rc] && !g[i][rc]) vis[i][rc] = 1,dfs(i,rc);
    }
    for (int i = 1;i <= rc;i++)
        for (int j = 1;j <= rc;j++)
            if (!vis[i][j] && !g[i][j])
                g[i][j] = 2;
    for (int i = 1;i <= rc;i++)
        for (int j = 1;j <= rc;j++)
            cout << g[i][j] << " \n"[j == rc];
    return 0;
}
