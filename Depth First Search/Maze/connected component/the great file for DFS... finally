#include<iostream>
#include<cstring>
using namespace std; const int N = 105;
int r,c,g[N][N],vis[N][N],maxx = 1,dx[] = {1,-1,0,0},dy[] = {0,0,-1,1},ans[N][N];
void dfs(int stx,int sty,int cnt){
    int flag = 0;
    for (int i = 0;i < 4;i++){
        int nx = stx + dx[i],ny = sty + dy[i];
        if ((nx > 0 && nx <= r && ny > 0 && ny <= c) && (g[nx][ny] < g[stx][sty] && !vis[nx][ny])){
            flag = 1;
            if (ans[nx][ny])
                ans[stx][sty] = max(ans[stx][sty],ans[nx][ny] + 1);
            else
                cnt++,
                vis[nx][ny] = 1,
                dfs(nx,ny,cnt),
                ans[stx][sty] = max(ans[stx][sty],ans[nx][ny] + 1),
                cnt--,
                vis[nx][ny] = 0;
        }
    }
    if (!flag)
        ans[stx][sty] = 1;
}
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> r >> c;
    for (int i = 1;i <= r;i++)
        for (int j = 1;j <= c;j++)
            cin >> g[i][j];
    vis[1][1] = 1;
    for (int i = 1;i <= r;i++)
        for (int j = 1;j <= c;j++){
            memset(vis,0,sizeof(vis));
            if (!ans[i][j])
                dfs(i,j,1);
            maxx = max(maxx,ans[i][j]);
        }
    cout << maxx;
    return 0;
}
