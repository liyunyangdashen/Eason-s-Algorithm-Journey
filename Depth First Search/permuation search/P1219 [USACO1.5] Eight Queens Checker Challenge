#include<iostream>
using namespace std; const int N = 15;
int n,box[N],cnt; bool col[N],l[2 * N],r[2 * N];
void dfs(int d){//r
    if (d > n){
        if (cnt++ < 3)
            for (int i = 1;i <= n;i++)
                cout << box[i] << " \n"[i == n];
        return ;
    }      //c
    for (int i = 1;i <= n;i++)
        if (!col[i] && !l[d + i - 1] && !r[d - i + n])
            box[d] = i,
            col[i] = l[d + i - 1] = r[d - i + n] = 1,
            dfs(d + 1),
            col[i] = l[d + i - 1] = r[d - i + n] = 0;
}
int main(){
    ios::sync_with_stdio(0);
    cin.tie(0);
    cout.tie(0);
    cin >> n;
    dfs(1);
    cout << cnt;
    return 0;
}
