#include<iostream>
#include<deque>
using namespace std; const int N = 1e5 + 5;
using ll = long long;
int n,f[N],s[N],l = 1,minn = 2e9; ll m,sum; deque<int> dq;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n >> m;
    for (int r = 1;r <= n;r++){
        cin >> f[r] >> s[r];
        sum += f[r];
        while (!dq.empty() && s[dq.back()] <= s[r])
            dq.pop_back();
        dq.push_back(r);
        while (l < r && sum - f[l] >= m){
            sum -= f[l];
            l++;
            if (!dq.empty() && dq.front() < l)
                dq.pop_front();
        }
        if (sum >= m)
            minn = min(minn,s[dq.front()]);
    }
    cout << minn;
    return 0;
}
