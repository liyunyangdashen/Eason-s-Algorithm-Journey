#include<iostream>
using namespace std; using ll = long long; const int N = 1e5 + 5;
int n,m,op,x,y; ll a[N],w[N << 2],lztag[N << 2],k;
void unionn(int x){w[x] = w[x << 1] + w[x << 1 | 1];}
void build(int x,int l,int r){if (l == r){w[x] = a[l]; return ;} ll mid = (l + r) / 2; build(x << 1,l,mid); build(x << 1 | 1,mid + 1,r); unionn(x);}
void apply(int x,int len,ll val){lztag[x] += val; w[x] += (ll)len * val;}
void pushdown(int x,int l,int r){ll mid = (l + r) / 2; apply(x << 1,mid - l + 1,lztag[x]); apply(x << 1 | 1,r - mid,lztag[x]); lztag[x] = 0;}
bool inRange(int L,int R,int l,int r){return l <= L && R <= r;} bool outRange(int L,int R,int l,int r){return R < l || r < L;}
void update(int x,int l,int r,int posl,int posr,ll val){if (inRange(l,r,posl,posr)) apply(x,r - l + 1,val); else if (!outRange(l,r,posl,posr)){ll mid = (l + r) / 2; pushdown(x,l,r); update(x << 1,l,mid,posl,posr,val); update(x << 1 | 1,mid + 1,r,posl,posr,val); unionn(x);}}
ll getSum(int x,int L,int R,int l,int r){if (inRange(L,R,l,r)) return w[x]; else if (!outRange(L,R,l,r)){ll mid = (L + R) / 2; pushdown(x,L,R); return getSum(x << 1,L,mid,l,r) + getSum(x << 1 | 1,mid + 1,R,l,r);} else return 0;}
int main(){
    ios::sync_with_stdio(0);
    cin.tie(0);
    cout.tie(0);
    cin >> n >> m;
    for (int i = 1;i <= n;i++)
        cin >> a[i];
    build(1,1,n);
    while (m--){
        cin >> op >> x >> y;
        if (x > y) swap(x,y);
        if (op - 2){
            cin >> k;
            update(1,1,n,x,y,(ll)k);
        }else
            cout << getSum(1,1,n,x,y) << '\n';
    }
    return 0;
}
