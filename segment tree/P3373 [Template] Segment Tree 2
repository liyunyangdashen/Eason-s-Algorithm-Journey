#include<iostream>
using namespace std; using ll = long long; const int N = 1e5 + 5;
struct tag{ll add = 0,mul = 1;}lztag[N << 2];
int n,m,p,op,x,y; ll a[N],w[N << 2],k;
void unionn(int x){w[x] = (w[x << 1] + w[x << 1 | 1]) % p;}
void build(int x,int l,int r){if (l == r){w[x] = a[l]; return ;} int mid = (l + r) >> 1; build(x << 1,l,mid); build(x << 1 | 1,mid + 1,r); unionn(x);}
bool inRange(int L,int R,int l,int r){return l <= L && R <= r;} bool outRange(int L,int R,int l,int r){return r < L || R < l;}
void apply(int x,int l,int r,ll valadd,ll valmul){w[x] = (w[x] * valmul + valadd * (r - l + 1)) % p; lztag[x].mul *= valmul; lztag[x].mul %= p; lztag[x].add *= valmul; lztag[x].add += valadd; lztag[x].add %= p;}
void pushdown(int x,int l,int r){int mid = (l + r) >> 1; apply(x << 1,l,mid,lztag[x].add,lztag[x].mul); apply(x << 1 | 1,mid + 1,r,lztag[x].add,lztag[x].mul); lztag[x].add = 0, lztag[x].mul = 1;}
void update(int x,int l,int r,int posl,int posr,ll valadd,ll valmul){if (inRange(l,r,posl,posr)) apply(x,l,r,valadd,valmul); else if (!outRange(l,r,posl,posr)){pushdown(x,l,r); int mid = (l + r) >> 1; update(x << 1,l,mid,posl,posr,valadd,valmul); update(x << 1 | 1,mid + 1,r,posl,posr,valadd,valmul); unionn(x);}}
ll getSum(int x,int L,int R,int l,int r){if (inRange(L,R,l,r)) return w[x]; else if (!outRange(L,R,l,r)){int mid = (L + R) >> 1; pushdown(x,L,R); return (getSum(x << 1,L,mid,l,r) + getSum(x << 1 | 1,mid + 1,R,l,r)) % p;}else return 0;}
int main(){
    ios::sync_with_stdio(0);
    cin.tie(0);
    cout.tie(0);
    cin >> n >> m >> p;
    for (int i = 1;i <= n;i++)
        cin >> a[i];
    build(1,1,n);
    while (m--){
        cin >> op >> x >> y;
        if (op - 3){
            cin >> k;
            if (op - 2)
                update(1,1,n,x,y,0,k);
            else
                update(1,1,n,x,y,k,1);
        }else
            cout << getSum(1,1,n,x,y) << '\n';
    }
    return 0;
}
