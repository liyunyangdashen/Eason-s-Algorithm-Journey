#include<iostream>
#include<deque>
using namespace std; const int N = 1e6 + 5;
int n,k,a[N],maxx[N]; deque<int> dqmax,dqmin;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n >> k;
    for (int i = 1;i <= n;i++){
        cin >> a[i];
        while (!dqmax.empty() && dqmax.front() + k - 1 < i)
            dqmax.pop_front();
        while (!dqmin.empty() && dqmin.front() + k - 1 < i)
            dqmin.pop_front();
        while (!dqmax.empty() && a[dqmax.back()] <= a[i])
            dqmax.pop_back();
        while (!dqmin.empty() && a[dqmin.back()] >= a[i])
            dqmin.pop_back();
        dqmax.push_back(i);
        dqmin.push_back(i);
        if (i >= k){
            cout << a[dqmin.front()] << ' ';
            maxx[i - k + 1] = a[dqmax.front()];
        }
    }
    cout << '\n';
    for (int i = 1;i <= n - k + 1;i++)
        cout << maxx[i] << ' ';
    return 0;
}
