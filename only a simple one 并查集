#include<iostream>
#include<cmath>
using namespace std; const int N = 3e4 + 5;
int t,x,y,fa[N],d[N],siz[N]; char c;
int findRt(int x){
    if (fa[x] == x) return x; 
    int f = fa[x]; fa[x] = findRt(f); 
    d[x] = d[x] + d[f]; 
    return fa[x];
}
void unionn(int x,int y){
    int fx = findRt(x),fy = findRt(y);  
    fa[fx] = fy; d[fx] = siz[fy]; 
    siz[fy] += siz[fx];
}
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> t;
    for (int i = 1;i <= N - 5;i++)
        fa[i] = i, siz[i] = 1;
    while (t--){
        cin >> c >> x >> y;
        if (c == 'M')
            unionn(x,y);
        else if (findRt(x) != findRt(y))
            cout << -1 << '\n';
        else
            cout << abs(d[x] - d[y]) - 1 << '\n';
    }
    return 0;
}
