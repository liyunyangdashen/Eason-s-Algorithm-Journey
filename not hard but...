#include<iostream>
#include<stack>
using namespace std; const int N = 1e4 + 5;
struct node{int n; char c;};
string a; stack<node> s; bool vis[N];
int main(){
    cin >> a;
    for (int i = 0;i < a.size();i++){
        if (a[i] == '(' || a[i] == '[')
            s.push(node{i,a[i]});
        else if (!s.empty())
            if (s.top().c == '(' && a[i] == ')' || s.top().c == '[' && a[i] == ']')
                vis[i] = 1,
                vis[s.top().n] = 1,
                s.pop();
    }
    for (int i = 0;i < a.size();i++){
        if (!vis[i]){
            if (a[i] == '(' || a[i] == ')')
                cout << "()";
            else
                cout << "[]";
            continue;
        }
        cout << a[i];
    }
    return 0;
}
