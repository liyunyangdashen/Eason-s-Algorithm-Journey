#include<iostream>
#include<stack>
using namespace std; const int N = 1e6;
int n,h[N],v[N],sum[N],ans; stack<int> s;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n;
    for (int i = 1;i <= n;i++){
        cin >> h[i] >> v[i];
        while (!s.empty() && h[i] > h[s.top()])
            s.pop();
        if (!s.empty())
            sum[s.top()] += v[i];
        s.push(i);
    }
    while (!s.empty())
        s.pop();
    for (int i = n;i >= 1;i--){
        while (!s.empty() && h[i] > h[s.top()])
            s.pop();
        if (!s.empty())
            sum[s.top()] += v[i];
        s.push(i);
    }
    for (int i = 1;i <= n;i++)
        ans = max(sum[i],ans);
    cout << ans;
    return 0;
}
