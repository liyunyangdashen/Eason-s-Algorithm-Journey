#include<iostream>
#include<cmath>
using namespace std; 
int t,xr,yr,xh,yh;
int gcd(int a,int b){
    int r;
    while (b){
        r = a % b;
        a = b;
        b = r;
    }
    return a;
}
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> t;
    while (t--){
        cin >> xr >> yr >> xh >> yh;
        if (gcd(abs(xr - xh),abs(yr - yh)) - 1)
            cout << "yes\n";
        else
            cout << "no\n";
    }
    return 0;
}
