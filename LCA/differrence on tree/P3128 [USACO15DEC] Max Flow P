#include<iostream>
#include<vector>
#include<cmath>
using namespace std; using ll = long long; const int N = 5e4 + 5;
int n,m,u,v,dep[N]; ll fa[N][20],t[N],s[N]; vector<int> adj[N];
void dfs(int st,int f){
    fa[st][0] = f;
    dep[st] = dep[f] + 1;
    for (auto e : adj[st])
        if (e != f)
            dfs(e,st);
}
int lowbit(int x){return x & -x;}
int LCA(int x,int y){
    if (dep[x] < dep[y]) swap(x,y);
    for (int i = dep[x] - dep[y];i >= 1;i -= lowbit(i))
        x = fa[x][(int)log2(lowbit(i))];
    if (x == y) return x;
    for (int i = log2(n);i >= 0;i--)
        if (fa[x][i] != fa[y][i])
            x = fa[x][i],y = fa[y][i];
    return fa[x][0];
}
void dfs_t(int st,int f){
    s[st] = t[st];
    for (auto e : adj[st])
        if (e != f)
            dfs_t(e,st),
            s[st] += s[e];
}
int main(){
    ios::sync_with_stdio(0);
    cin.tie(0);
    cout.tie(0);
    cin >> n >> m;
    for (int i = 1;i < n;i++){
        cin >> u >> v;
        adj[u].push_back(v);
        adj[v].push_back(u);
    }
    dep[0] = -1;
    dfs(1,0);
    for (int j = 1;j <= log2(n);j++)
        for (int i = 1;i <= n;i++)
            fa[i][j] = fa[fa[i][j - 1]][j - 1];
    while (m--){
        cin >> u >> v;
        int lca = LCA(u,v);
        t[u]++, t[fa[lca][0]]--,
        t[v]++, t[lca]--;
    }
    dfs_t(1,0);
    ll ans = -2e9;
    for (int i = 1;i <= n;i++)
        ans = max(ans,s[i]);
    cout << ans;
    return 0;
}
