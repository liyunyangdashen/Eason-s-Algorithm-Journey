#include<iostream>
#include<cmath>
using namespace std; const int N = 1e6 + 5; // 1e4 + 5
int n,m,l,r,st[N][21];
int gcd (int a,int b){ // or int r = a % b; while(r) a = b,b = r,r = a % b;
    int r;
    while (b)
        r = a % b,
        a = b,
        b = r;
    return a;
}
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n >> m;
    for (int i = 1;i <= n;i++){
        cin >> l;
        st[i][0] = l;
    }
    for (int j = 1;j <= __lg(n);j++)//log2(n)
        for (int i = 1;i + (1 << j) - 1 <= n;i++)//-1 is very importANT!!!!!!
            st[i][j] = gcd(st[i][j - 1],st[i + (1 << (j - 1))][j - 1]);
    while (m--){
        cin >> l >> r;
        if (l > r) swap(l,r);//don't need that
        int k = __lg(r - l + 1);//log2(r - l + 1) or log(r - l + 1) / log(2)
        cout << gcd(st[l][k],st[r - (1 << k) + 1][k]) << '\n';
    }
    return 0;
}
