#include<iostream>
using namespace std; const int N = 1005;
int n,m,fa[N],x,y,cnt;
int findRt(int x){
    if (fa[x] == x) return x;
    return fa[x] = findRt(fa[x]);
}
void unionn(int x,int y){
    int fx = findRt(x),fy = findRt(y);
    if (fx > fy) swap(fx,fy);
    if (fx != fy) fa[fx] = fy;
}
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    while (cin >> n){
        if (!n) exit(0);
        cnt = 0;
        for (int i = 1;i <= n;i++)
            fa[i] = i;
        cin >> m;
        while (m--){
            cin >> x >> y;
            if (findRt(x) != findRt(y))
                cnt++;
            unionn(x,y);
        }
        cout << n - cnt - 1 << '\n';
    }
    return 0;
}
