#include<iostream>
using namespace std; const int N = 10; //总共9个数
bool chk(int x){ //检查一个数里是否有不符合规则的
    int h = x / 100,t = x / 10 % 10,o = x % 10;//百、十、个
    return !(h == t || t == o || h == o) && h && t && o;
    //       全部不相同            且         不为零
}
bool chk2(int x,int y){//检查两个数之中是否有不符合规则的
    int h1 = x / 100,t1 = x / 10 % 10,o1 = x % 10;//第一个数拆分
    int h2 = y / 100,t2 = y / 10 % 10,o2 = y % 10;//第二个数拆分
    return chk(x) && chk(y) && !(h1 == h2 || h1 == t2 || h1 == o2 || t1 == h2 || t1 == t2 || t1 == o2 || o1 == h2 || o1 == t2 || o1 == o2);
    //检查两个单独的数 和 每个数位两两之间是否重复
}
bool chk3(int x,int y,int z){//检查两个数之中是否有不符合规则的
    return chk2(x,y) && chk2(y,z) && chk2(z,x);
    //检查每个数两两之间是否重复
