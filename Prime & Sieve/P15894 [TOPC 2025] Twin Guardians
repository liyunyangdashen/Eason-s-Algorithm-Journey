#include<iostream>
#include<cmath>
using namespace std; const int N = 1e6 + 5;
int t,a,b,p[N],cnt; bool vis[N];
void EulerSieve(int n){
    vis[0] = vis[1] = 1;
    for (int i = 2;i <= n;i++){
        if (!vis[i]) p[++cnt] = i;
        for (int j = 1;j <= cnt && i * p[j] < n;j++){
            vis[i * p[j]] = 1;
            if (!(i % p[j])) break;
        }
    }
}
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> t;
    EulerSieve(N - 5);
    while (t--){
        cin >> a >> b;
        cout << "NY"[abs(a - b) == 2 && !vis[a] && !vis[b]] << '\n';
    }
    return 0;
}
