#include<iostream>
using namespace std; const int N = 1e8 + 5;
int n,q,k,cnt,p[N / 10]; bool vis[N];
void eulerSieve(int n){
    vis[0] = vis[1] = 1;
    for (int i = 2;i <= n;i++){
        if (!vis[i]) p[++cnt] = i;
        for (int j = 1;j <= cnt && 1LL * i * p[j] <= n;j++){
            vis[i * p[j]] = 1;
            if (!(i % p[j])) break;
        }
    }
}
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n >> q;
    eulerSieve(n);
    while (q--){
        cin >> k;
        cout << p[k] << '\n';
    }
    return 0;
}
