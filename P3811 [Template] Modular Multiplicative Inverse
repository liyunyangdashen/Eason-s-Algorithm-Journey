#include<iostream>
using namespace std; const int N = 3e6 + 5;
int n; long long p,ans[N];
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> n >> p;
    ans[1] = 1;
    cout << ans[1] << '\n';
    for (int i = 2;i <= n;i++){
        ans[i] = (long long)(p - p / i) * ans[p % i] % p;
        cout << ans[i] << '\n';
    }
    return 0;
}
