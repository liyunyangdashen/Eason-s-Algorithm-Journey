#include<iostream>
using namespace std; using ll = long long; const int N = 5e5 + 5;
int n,m,tr[N],op,x,y;
int lowbit(int x){return x & (-x);}
void update(int x,int k){for (int i = x;i <= n;i += lowbit(i)) tr[i] += k;}
ll getSum(int x){ll sum = 0; for (int i = x;i;i -= lowbit(i)) sum += tr[i]; return sum;}
int main(){
    ios::sync_with_stdio(0);
    cin.tie(0);
    cout.tie(0);
    cin >> n >> m;
    for (int i = 1;i <= n;i++){
        cin >> x;
        update(i,x);
    }
    while (m--){
        cin >> op >> x >> y;
        if (op - 2)
            update(x,y);
        else
            cout << getSum(y) - getSum(x - 1) << '\n';
    }
    return 0;
}
