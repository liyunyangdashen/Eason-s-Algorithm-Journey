#include<iostream>
using namespace std; using ll = long long; const int N = 1e5 + 5;
int n,m,x,y; ll tr[N]; char op;
int lowbit(int x){return x & (-x);}
void update(int x,int y){for (int i = x;i <= n;i += lowbit(i)) tr[i] += y;}
ll getSum(int x){ll sum = 0; for (int i = x;i;i -= lowbit(i)) sum += tr[i]; return sum;}
int main(){
    ios::sync_with_stdio(0);
    cin.tie(0);
    cout.tie(0);
    cin >> n >> m;
    while (m--){
        cin >> op >> x >> y;
        if (op - 'y')
            update(x,y);
        else
            cout << getSum(y) - getSum(x - 1) << '\n';
    }
    return 0;
}
