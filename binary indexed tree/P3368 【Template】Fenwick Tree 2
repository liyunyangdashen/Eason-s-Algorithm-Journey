#include<iostream>
using namespace std; using ll = long long; const int N = 5e5 + 5;
int n,m,op,x,y,k,tr[N];
int lowbit(int x){return x & (-x);}
void update(int x,int y){for (int i = x;i <= n;i += lowbit(i)) tr[i] += y;}
ll getSum(int x){ll sum = 0; for (int i = x;i;i -= lowbit(i)) sum += tr[i]; return sum;}
int main(){
    ios::sync_with_stdio(0);
    cin.tie(0);
    cout.tie(0);
    cin >> n >> m;
    for (int i = 1;i <= n;i++){
        cin >> x;
        update(i,x - y);
        y = x;
    }
    while (m--){
        cin >> op >> x;
        if (op - 2){
            cin >> y >> k;
            update(x,k); update(y + 1,-k);
        }else
            cout << getSum(x) << '\n';
    }
    return 0;
}
