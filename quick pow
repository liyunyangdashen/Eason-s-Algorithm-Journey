#include<iostream>
using namespace std; 
using ll = long long;
ll a,b,p;
ll quick_pow(ll a,ll b,ll p){
    ll ans = 1;
    a %= p;
    while (b){
        if (b & 1)
            ans = (ans * a) % p;
        a *= a, a %= p,
        b >>= 1;
    }
    return ans;
}
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    cin >> a >> b >> p;
    cout << a << '^' << b << " mod " << p << '=' << quick_pow(a,b,p);
    return 0;
}
